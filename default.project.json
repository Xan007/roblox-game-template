{
  "name": "rojo-showcase-template",
  "emitLegacyScripts": false,
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "src": {
        "$className": "Folder",
        "shared": {
          "$path": "src/shared"
        },
        "client": {
          "$path": "src/client"
        },
        "server": {
          "$path": "src/server"
        }
      },

      
      "roblox_packages": {
        "$path": "roblox_packages"
      },

      "roblox_server_packages": {
        "$path": "roblox_server_packages"
      },
      
      "$ignoreUnknownInstances": true
    }
  }
}